[/CENTER]

[LIST]
[*][COLOR=#50fa7b]●[/COLOR] [COLOR=#CCCCCC][B]Server:[/B] Paper 1.17 – 26.1.2 [COLOR=#888888](Spigot likely compatible but untested — Paper recommended)[/COLOR][/COLOR]
[*][COLOR=#50fa7b]●[/COLOR] [COLOR=#CCCCCC][B]Java:[/B] 16 or higher[/COLOR]
[*][COLOR=#50fa7b]●[/COLOR] [COLOR=#CCCCCC][B]No external plugins required[/B][/COLOR]
[/LIST]

[CENTER]
[SIZE=1][COLOR=#333333]━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━[/COLOR][/SIZE]
[/CENTER]

[CENTER]
[SIZE=5][B][COLOR=#FF4444]◆[/COLOR] [COLOR=#FFFFFF]INSTALLATION[/COLOR] [COLOR=#FF4444]◆[/COLOR][/B][/SIZE]
[/CENTER]

[LIST=1]
[*][COLOR=#CCCCCC]Download [B]NewBedwars-1.0.0-beta.jar[/B][/COLOR]
[*][COLOR=#CCCCCC]Drop it into your server's [B]/plugins/[/B] folder[/COLOR]
[*][COLOR=#CCCCCC]Start your server — config files are generated automatically[/COLOR]
[*][COLOR=#CCCCCC]Set your lobby spawn: [B]/bw setLobby[/B][/COLOR]
[*][COLOR=#CCCCCC]Create your first arena: [B]/bw arena create myArena[/B][/COLOR]
[*][COLOR=#CCCCCC]Enter setup: [B]/bw arena setup myArena[/B] and follow the [B]/bw arena[/B] checklist[/COLOR]
[*][COLOR=#CCCCCC]Enable the arena: [B]/bw arena enable myArena[/B] — done![/COLOR]
[/LIST]

[CENTER]
[SIZE=1][COLOR=#333333]━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━[/COLOR][/SIZE]
[/CENTER]

