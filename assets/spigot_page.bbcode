[CENTER]
[SIZE=5][B][COLOR=#FF4444]◆[/COLOR] [COLOR=#FFFFFF]INSTALLATION[/COLOR] [COLOR=#FF4444]◆[/COLOR][/B][/SIZE]
[/CENTER]

[LIST=1]
[*][COLOR=#CCCCCC]Download [B]NewBedwars-1.0.2-beta.jar[/B][/COLOR]
[*][COLOR=#CCCCCC]Drop it into your server's [B]/plugins/[/B] folder[/COLOR]
[*][COLOR=#CCCCCC]Start the server — config files generate automatically[/COLOR]
[*][COLOR=#CCCCCC]Set your lobby spawn: [B]/bw setLobby[/B][/COLOR]
[*][COLOR=#CCCCCC]Create your first arena: [B]/bw arena create myArena[/B][/COLOR]
[*][COLOR=#CCCCCC]Follow the checklist shown by [B]/bw arena[/B][/COLOR]
[*][COLOR=#CCCCCC]Save the arena: [B]/bw save[/B][/COLOR]
[*][COLOR=#CCCCCC]Enable when ready: [B]/bw arena enable myArena[/B][/COLOR]
[/LIST]

