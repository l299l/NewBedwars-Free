[/CENTER]

[LIST]
[*][COLOR=#50fa7b]●[/COLOR] [COLOR=#CCCCCC][B]Server:[/B] Paper 1.17 – 26.2 [COLOR=#888888](Spigot will probably work too, but it's untested, so Paper is recommended)[/COLOR][/COLOR]
[*][COLOR=#50fa7b]●[/COLOR] [COLOR=#CCCCCC][B]Java:[/B] 16 or higher[/COLOR]
[*][COLOR=#50fa7b]●[/COLOR] [COLOR=#CCCCCC][B]No other plugins required[/B] [COLOR=#888888](PlaceholderAPI and WorldEdit/FAWE are optional)[/COLOR][/COLOR]
[/LIST]

[CENTER]
[SIZE=1][COLOR=#333333]━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━[/COLOR][/SIZE]
[/CENTER]

[CENTER]
[SIZE=5][B][COLOR=#FF4444]◆[/COLOR] [COLOR=#FFFFFF]INSTALLATION[/COLOR] [COLOR=#FF4444]◆[/COLOR][/B][/SIZE]
[/CENTER]

[LIST=1]
[*][COLOR=#CCCCCC]Grab the jar from the [URL='https://modrinth.com/plugin/new-bedwars/versions'][B]latest Modrinth release[/B][/URL][/COLOR]
[*][COLOR=#CCCCCC]Drop it into your server's [B]/plugins/[/B] folder[/COLOR]
[*][COLOR=#CCCCCC]Start the server. Config files generate automatically[/COLOR]
[*][COLOR=#CCCCCC]Set your lobby spawn: [B]/bw setLobby[/B][/COLOR]
[*][COLOR=#CCCCCC]Create your first arena: [B]/bw arena create myArena[/B][/COLOR]
[*][COLOR=#CCCCCC]Follow the setup checklist shown by [B]/bw arena[/B][/COLOR]
[*][COLOR=#CCCCCC]Save the arena: [B]/bw save[/B][/COLOR]
[*][COLOR=#CCCCCC]Enable it when ready: [B]/bw arena enable myArena[/B][/COLOR]
[/LIST]

[CENTER]
[SIZE=1][COLOR=#333333]━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━[/COLOR][/SIZE]
