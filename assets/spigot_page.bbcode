[CENTER]
[SIZE=1][COLOR=#666666]━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━[/COLOR][/SIZE]
[/CENTER]

[CENTER]
[SIZE=5][B][COLOR=#FF4444]◆[/COLOR] [COLOR=#FFFFFF]OVERVIEW[/COLOR] [COLOR=#FF4444]◆[/COLOR][/B][/SIZE]
[/CENTER]

[COLOR=#CCCCCC]
[B]NewBedwars[/B] is a modern, fully configurable Bedwars plugin built from the ground up for [COLOR=#50fa7b][B]Paper 1.17+[/B][/COLOR]. It delivers the classic Bedwars experience with a powerful setup system, customizable shops and upgrades, multi-arena support, and deep gamerule control — all without any external dependencies beyond Paper itself.

Whether you're a small server or building a full Bedwars network, NewBedwars gives you the tools to create polished, production-ready Bedwars arenas with minimal effort.
[/COLOR]

[CENTER]
[SIZE=1][COLOR=#333333]━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━[/COLOR][/SIZE]
[/CENTER]

[CENTER]
[SIZE=5][B][COLOR=#FF4444]◆[/COLOR] [COLOR=#FFFFFF]KEY FEATURES[/COLOR] [COLOR=#FF4444]◆[/COLOR][/B][/SIZE]
[/CENTER]

[COLOR=#FFFFFF][B]⚔ Gameplay[/B][/COLOR]
[LIST]
[*][COLOR=#50fa7b]✔[/COLOR] [COLOR=#CCCCCC][B]Multi-Arena support[/B] — run as many simultaneous arenas as your server can handle[/COLOR]
[*][COLOR=#50fa7b]✔[/COLOR] [COLOR=#CCCCCC][B]Team-based Bedwars[/B] — configurable team count, colors, and max players per team[/COLOR]
[*][COLOR=#50fa7b]✔[/COLOR] [COLOR=#CCCCCC][B]Quick void detection[/B] — instant void death before Y threshold[/COLOR]
[*][COLOR=#50fa7b]✔[/COLOR] [COLOR=#CCCCCC][B]Build protection areas[/B] — per-team zones where blocks cannot be placed[/COLOR]
[*][COLOR=#50fa7b]✔[/COLOR] [COLOR=#CCCCCC][B]Rejoin system[/B] — players can reconnect to their arena within a configurable time window[/COLOR]
[*][COLOR=#50fa7b]✔[/COLOR] [COLOR=#CCCCCC][B]Blast protection glass[/B] — special item that creates explosion-resistant barriers[/COLOR]
[*][COLOR=#50fa7b]✔[/COLOR] [COLOR=#CCCCCC][B]Traps[/B] — trigger team traps when enemies enter your base area[/COLOR]
[/LIST]

[COLOR=#FFFFFF][B]💬 Chat & Visibility[/B][/COLOR]
[LIST]
[*][COLOR=#50fa7b]✔[/COLOR] [COLOR=#CCCCCC][B]Arena chat isolation[/B] — each arena has its own chat; lobby players and other arenas are completely cut off[/COLOR]
[*][COLOR=#50fa7b]✔[/COLOR] [COLOR=#CCCCCC][B]Team chat[/B] — type [B]!message[/B] to send a team-only message; toggled per arena via gamerule[/COLOR]
[*][COLOR=#50fa7b]✔[/COLOR] [COLOR=#CCCCCC][B]Global arena chat[/B] — optional arena-wide channel, independently toggled per arena via gamerule[/COLOR]
[*][COLOR=#50fa7b]✔[/COLOR] [COLOR=#CCCCCC][B]Tab list isolation[/B] — each arena gets its own tab; lobby players are hidden from arena players and vice versa[/COLOR]
[/LIST]

[COLOR=#FFFFFF][B]🛒 Shop & Economy[/B][/COLOR]
[LIST]
[*][COLOR=#50fa7b]✔[/COLOR] [COLOR=#CCCCCC][B]Fully YAML-driven shop GUIs[/B] — drag & drop item configuration, no hardcoding[/COLOR]
[*][COLOR=#50fa7b]✔[/COLOR] [COLOR=#CCCCCC][B]Team Upgrades shop[/B] — forge, traps, heal pool, dragon buff, and more[/COLOR]
[*][COLOR=#50fa7b]✔[/COLOR] [COLOR=#CCCCCC][B]Custom item logic[/B] — Bridge Egg, Fireball, Speed/Jump/Invisibility potions[/COLOR]
[*][COLOR=#50fa7b]✔[/COLOR] [COLOR=#CCCCCC][B]Iron, Gold, Diamond & Emerald generators[/B] — with level upgrades tied to game phases[/COLOR]
[*][COLOR=#50fa7b]✔[/COLOR] [COLOR=#CCCCCC][B]Generator particle effects[/B] — visual indicators floating above generators[/COLOR]
[/LIST]

[COLOR=#FFFFFF][B]🐉 Game Phases[/B][/COLOR]
[LIST]
[*][COLOR=#50fa7b]✔[/COLOR] [COLOR=#CCCCCC][B]Configurable phase system[/B] — define custom phases with names, durations, and triggered actions[/COLOR]
[*][COLOR=#50fa7b]✔[/COLOR] [COLOR=#CCCCCC][B]Phase actions[/B] — upgrade generators, destroy all beds, end game, spawn Ender Dragons[/COLOR]
[*][COLOR=#50fa7b]✔[/COLOR] [COLOR=#CCCCCC][B]Ender Dragon event[/B] — dragons spawn per-team based on Dragon Buff upgrade level, fire fireballs at enemies[/COLOR]
[*][COLOR=#50fa7b]✔[/COLOR] [COLOR=#CCCCCC][B]Natural regeneration disable[/B] — configurable phase trigger[/COLOR]
[*][COLOR=#50fa7b]✔[/COLOR] [COLOR=#CCCCCC][B]Team forge disable[/B] — remove team iron/gold generators in late game[/COLOR]
[/LIST]

[COLOR=#FFFFFF][B]🎭 Display & HUD[/B][/COLOR]
[LIST]
[*][COLOR=#50fa7b]✔[/COLOR] [COLOR=#CCCCCC][B]Custom Bossbar[/B] — YAML-configurable templates for waiting, in-game, and ending states[/COLOR]
[*][COLOR=#50fa7b]✔[/COLOR] [COLOR=#CCCCCC][B]Scoreboard[/B] — per-player scoreboards with full template support[/COLOR]
[*][COLOR=#50fa7b]✔[/COLOR] [COLOR=#CCCCCC][B]Spectator mode[/B] — fly around and teleport to players via compass GUI[/COLOR]
[*][COLOR=#50fa7b]✔[/COLOR] [COLOR=#CCCCCC][B]Spectator effects GUI[/B] — special effects for spectators[/COLOR]
[*][COLOR=#50fa7b]✔[/COLOR] [COLOR=#CCCCCC][B]TNT particle indicator[/B] — red dust particles above players holding TNT[/COLOR]
[*][COLOR=#50fa7b]✔[/COLOR] [COLOR=#CCCCCC][B]Victory fireworks[/B] — firework show for the winning team[/COLOR]
[/LIST]

[COLOR=#FFFFFF][B]⚙ Administration & Setup[/B][/COLOR]
[LIST]
[*][COLOR=#50fa7b]✔[/COLOR] [COLOR=#CCCCCC][B]In-game setup wizard[/B] — configure arenas without editing any files[/COLOR]
[*][COLOR=#50fa7b]✔[/COLOR] [COLOR=#CCCCCC][B]Normal & Advanced setup modes[/B] — full control over every arena parameter[/COLOR]
[*][COLOR=#50fa7b]✔[/COLOR] [COLOR=#CCCCCC][B]Arena info command[/B] — see a complete overview of what's configured and what's missing[/COLOR]
[*][COLOR=#50fa7b]✔[/COLOR] [COLOR=#CCCCCC][B]JSON arena persistence[/B] — arenas saved automatically, survive restarts[/COLOR]
[*][COLOR=#50fa7b]✔[/COLOR] [COLOR=#CCCCCC][B]Per-arena gamerules[/B] — random teams, spectators, team/global chat, team damage, permanent swords[/COLOR]
[*][COLOR=#50fa7b]✔[/COLOR] [COLOR=#CCCCCC][B]Multi-language[/B] — English and Polish included, fully translatable[/COLOR]
[*][COLOR=#50fa7b]✔[/COLOR] [COLOR=#CCCCCC][B]Party system[/B] — players can group up and join together[/COLOR]
[/LIST]

[CENTER]
[SIZE=1][COLOR=#333333]━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━[/COLOR][/SIZE]
[/CENTER]

[CENTER]
[SIZE=5][B][COLOR=#FF4444]◆[/COLOR] [COLOR=#FFFFFF]COMMANDS[/COLOR] [COLOR=#FF4444]◆[/COLOR][/B][/SIZE]
[/CENTER]

[COLOR=#FFFFFF][B]Player Commands[/B][/COLOR]
[CODE]
/bw join [arena]      — Open arena selector or join a specific arena
/bw rejoin            — Rejoin your previous arena (within rejoin window)
/bw lobby             — Leave the arena and return to lobby
/bw spectate [arena]  — Join a running arena as spectator
/bw lang <en|pl>      — Change your display language
/bw help              — Show all available commands
/lobby                — Shortcut: teleport to lobby
/lang <en|pl>         — Shortcut: change language
[/CODE]

[COLOR=#FFFFFF][B]Admin Commands[/B][/COLOR]
[CODE]
/bw arena create <name>          — Create a new arena
/bw arena delete <name>          — Delete an arena permanently
/bw arena enable <name>          — Enable a configured arena
/bw arena disable <name>         — Disable a running arena
/bw arena setup <name>           — Enter setup mode for an arena
/bw setLobby                     — Set the main lobby spawn point
/bw setupGuis                    — Open the GUI configuration tool
/bw manageGame                   — In-game admin management panel

— Inside setup mode —
/bw arena                        — Show full arena status and missing fields
/bw createTeam <name> <color>    — Create a team for the arena
/bw setSpawn <team>              — Set a team's spawn point
/bw setBed <team>                — Set a team's bed location
/bw setShop <team>               — Set a team's shop NPC location
/bw setUpgrades <team>           — Set a team's upgrades NPC location
/bw setGenerator <team>          — Set a team's iron/gold generator
/bw setGenerator                 — Add a diamond/emerald generator
/bw setBuildProtPos1/2 <team>    — Define build-protection zone corners
/bw setBasePos1/2 <team>         — Define team base zone corners
/bw setQuickVoidY <y>            — Set the quick-void Y level
/bw setWaitingPos1/2             — Define waiting lobby zone corners
/bw setWaitingSpawn              — Set the waiting area spawn point
/bw setWaitingTime <seconds>     — Set countdown time before game starts
/bw save                         — Save all arena settings
/bw leave                        — Leave setup mode
[/CODE]

[CENTER]
[SIZE=1][COLOR=#333333]━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━[/COLOR][/SIZE]
[/CENTER]

[CENTER]
[SIZE=5][B][COLOR=#FF4444]◆[/COLOR] [COLOR=#FFFFFF]PERMISSIONS[/COLOR] [COLOR=#FF4444]◆[/COLOR][/B][/SIZE]
[/CENTER]

[COLOR=#FFFFFF][B]Admin Permissions[/B][/COLOR]
[CODE]
newbedwars.bw.admin          — Full admin access; grants all sub-permissions (default: op)
newbedwars.bw.arena          — Manage arenas: create/delete/enable/disable/setup (default: op)
newbedwars.bw.arena.create   — Create arenas (default: op)
newbedwars.bw.arena.delete   — Delete arenas (default: op)
newbedwars.bw.arena.enable   — Enable arenas (default: op)
newbedwars.bw.arena.disable  — Disable arenas (default: op)
newbedwars.bw.arena.setup    — Enter arena setup mode (default: op)
newbedwars.bw.setlobby       — Set the lobby location (default: op)
newbedwars.bw.setupguis      — Open the GUI editor (default: op)
newbedwars.bw.managegame     — Manage running games (default: op)
newbedwars.bw.bypass         — Bypass setup-mode restrictions (default: op)
[/CODE]

[COLOR=#FFFFFF][B]Player Permissions[/B][/COLOR]
[CODE]
newbedwars.bw.player   — Bundle; grants all player permissions below (default: true)
newbedwars.bw.join     — Join arenas (default: true)
newbedwars.bw.lobby    — Teleport to lobby (default: true)
newbedwars.bw.rejoin   — Rejoin after disconnect (default: true)
newbedwars.bw.spectate — Spectate arenas (default: true)
newbedwars.bw.lang     — Change language (default: true)
newbedwars.bw.help     — View help menu (default: true)
[/CODE]
[COLOR=#888888][I]Set RequireJoinPermission or RequireLobbyPermission to true in config.yml to restrict join/lobby to players with the explicit permission (both default to false — open to everyone).[/I][/COLOR]

[CENTER]
[SIZE=1][COLOR=#333333]━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━[/COLOR][/SIZE]
[/CENTER]

